# Nach secrets.yaml kopieren und ausfüllen (secrets.yaml nicht ins Git einchecken).

wifi_ssid: "WLAN-Name"
wifi_password: "WLAN-Passwort"

ota_password: "OTA-Passwort"

# Home Assistant / ESPHome Native API (seit ESPHome 2026.1.0 Pflicht statt api.password)
# Schlüssel erzeugen: openssl rand -base64 32
api_encryption_key: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx="

# Fallback-AP (mindestens 8 Zeichen)
fallback_ap_password: "AenderMich!"
